# Clé de signature du token de test de la PoC (HMAC-SHA256).
# Stub du service d'identité UNIQUEMENT — sans rapport avec la vraie stack d'identité
# (OIDC / argon2id), spécifiée seulement à l'architecture (ADR-006).
# Copier ce fichier en .env (jamais versionné) et remplacer la valeur ci-dessous.
# La clé n'est JAMAIS écrite en dur dans le code.
POC_TOKEN_SIGNING_KEY=replace-me

# Port d'écoute du serveur (optionnel ; défaut 8080 ; entier 1..65535).
# Décommenter pour changer (par ex. si 8080 est déjà occupé).
# POC_PORT=8080
